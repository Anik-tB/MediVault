# Database Configuration
PORT=5000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medivault
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional Gemini prescription verification for admin order review
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# Optional: use this instead of the DB_* values above if you prefer one string.
# DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/medivault
